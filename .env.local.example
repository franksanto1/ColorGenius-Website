# =======================================================
# Versani Website — Environment Variables
# =======================================================
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` to git.

# Public site URL (used for metadata, OG, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://versani.ai

# -------------------------------------------------------
# Supabase (shared with the Versani app)
# -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------------------
# Stripe
# -------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Versani tier price IDs (from the Stripe dashboard)
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_STUDIO=
NEXT_PUBLIC_STRIPE_PRICE_STUDIO_PLUS=
NEXT_PUBLIC_STRIPE_PRICE_SALON_SEAT=

# -------------------------------------------------------
# Admin console
# -------------------------------------------------------
# Temporary feature flag until Supabase auth is wired.
# Set to `true` to preview the /admin placeholder.
NEXT_PUBLIC_ADMIN_ENABLED=false
