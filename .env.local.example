# =======================================================
# Versani Website — Environment Variables
# =======================================================
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` to git.

# Public site URL (used for metadata, OG, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://versani.ai

# -------------------------------------------------------
# Supabase (shared with the Versani app)
# -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the browser.
# Used for admin queries and Stripe webhook DB updates.
SUPABASE_SERVICE_ROLE_KEY=

# -------------------------------------------------------
# Stripe (billing)
# -------------------------------------------------------
# Public key — safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server-only keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Versani tier price IDs (server-only — used by checkout API)
# Create in Stripe Dashboard → Products, then paste IDs here.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_YEARLY=
STRIPE_PRICE_STUDIO_PLUS_MONTHLY=
STRIPE_PRICE_STUDIO_PLUS_YEARLY=

# -------------------------------------------------------
# Admin console
# -------------------------------------------------------
# Legacy feature flag. Real gating now handled by middleware + is_admin
# column on profiles. See SCHEMA-REQUIREMENTS.md.
NEXT_PUBLIC_ADMIN_ENABLED=false
